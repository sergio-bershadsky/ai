#!/usr/bin/env python3
"""
Secondbrain Tracking Library

Auto-generated CRUD operations for microdatabase entities.
Project: {{project_name}}
Generated: {{timestamp}}
"""

import yaml
from pathlib import Path
from datetime import datetime, date
from typing import Any, Optional, List

try:
    import jsonschema
    HAS_JSONSCHEMA = True
except ImportError:
    HAS_JSONSCHEMA = False


DATA_DIR = Path(__file__).parent.parent / "data"
CONFIG_PATH = DATA_DIR / "config.yaml"


class ValidationError(Exception):
    """Raised when data fails schema validation."""
    pass


# ============================================================================
# Core YAML Operations
# ============================================================================

def _load_yaml(path: Path) -> Any:
    """Load YAML file."""
    if not path.exists():
        return None
    with open(path, 'r') as f:
        return yaml.safe_load(f)


def _save_yaml(path: Path, data: Any) -> None:
    """Save data to YAML file with date handling."""
    def date_representer(dumper, data):
        return dumper.represent_scalar('tag:yaml.org,2002:str', data.isoformat())

    yaml.add_representer(date, date_representer)
    yaml.add_representer(datetime, date_representer)

    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, 'w') as f:
        yaml.dump(data, f, default_flow_style=False, allow_unicode=True, sort_keys=False)


def _validate(data: Any, schema: dict) -> None:
    """Validate data against JSON Schema."""
    if not HAS_JSONSCHEMA:
        return
    try:
        jsonschema.validate(instance=data, schema=schema)
    except jsonschema.ValidationError as e:
        raise ValidationError(f"Validation failed: {e.message}")


# ============================================================================
# Config Operations
# ============================================================================

def load_config() -> dict:
    """Load configuration."""
    return _load_yaml(CONFIG_PATH) or {}


def save_config(data: dict) -> None:
    """Save configuration."""
    _save_yaml(CONFIG_PATH, data)


def get_entity_config(entity: str) -> Optional[dict]:
    """Get entity configuration."""
    config = load_config()
    return config.get('entities', {}).get(entity)


def is_entity_enabled(entity: str) -> bool:
    """Check if entity is enabled."""
    entity_config = get_entity_config(entity)
    return entity_config.get('enabled', False) if entity_config else False


def list_enabled_entities() -> List[str]:
    """List all enabled entities."""
    config = load_config()
    entities = config.get('entities', {})
    return [name for name, cfg in entities.items() if cfg.get('enabled', False)]


# ============================================================================
# Monthly Shard Operations (Generic)
# ============================================================================

def _get_shard_file(entity: str, year_month: str = None) -> Path:
    """Get path to a monthly shard file for any entity."""
    if year_month is None:
        year_month = date.today().strftime('%Y-%m')
    return DATA_DIR / entity / f"{year_month}.yaml"


def _get_meta_path(entity: str) -> Path:
    """Get path to entity meta.yaml."""
    return DATA_DIR / entity / "meta.yaml"


def load_meta(entity: str) -> dict:
    """Load entity metadata (last_number, shard list). Always tiny."""
    path = _get_meta_path(entity)
    return _load_yaml(path) or {'shards': []}


def save_meta(entity: str, data: dict) -> None:
    """Save entity metadata."""
    _save_yaml(_get_meta_path(entity), data)


def list_shards(entity: str) -> List[str]:
    """List all monthly shards for an entity (newest first)."""
    entity_dir = DATA_DIR / entity
    if not entity_dir.exists():
        return []
    return sorted([
        f.stem for f in entity_dir.glob("*.yaml")
        if f.stem not in ("schema", "meta", "records")
    ], reverse=True)


def load_shard(entity: str, year_month: str = None) -> List[dict]:
    """Load records from a single monthly shard."""
    path = _get_shard_file(entity, year_month)
    return _load_yaml(path) or []


def save_shard(entity: str, records: List[dict], year_month: str = None) -> None:
    """Save records to a monthly shard."""
    path = _get_shard_file(entity, year_month)
    _save_yaml(path, records)


def _ensure_shard_registered(entity: str, year_month: str) -> None:
    """Ensure a shard is listed in meta.yaml."""
    meta = load_meta(entity)
    if year_month not in meta.get('shards', []):
        meta.setdefault('shards', []).append(year_month)
        meta['shards'] = sorted(meta['shards'])
        save_meta(entity, meta)


# ============================================================================
# Generic Entity Operations (Shard-Aware)
# ============================================================================

def load_entity_records(entity: str) -> dict:
    """Load ALL records for an entity across all shards.

    Use sparingly — this reads every shard file. Prefer load_shard()
    for operations that only need the current month.
    """
    # Support legacy flat records.yaml
    legacy_path = DATA_DIR / entity / "records.yaml"
    if legacy_path.exists():
        data = _load_yaml(legacy_path)
        return data or {'records': []}

    # Sharded: collect from all monthly files
    meta = load_meta(entity)
    all_records = []
    for shard in sorted(meta.get('shards', list_shards(entity))):
        all_records.extend(load_shard(entity, shard))

    result = {'records': all_records}
    if 'last_number' in meta:
        result['last_number'] = meta['last_number']
    return result


def save_entity_records(entity: str, data: dict) -> None:
    """Save entity records. Legacy compatibility — writes flat file."""
    entity_dir = DATA_DIR / entity
    records_path = entity_dir / "records.yaml"
    _save_yaml(records_path, data)


def add_record(entity: str, record: dict) -> dict:
    """Add a record to the current month's shard."""
    year_month = date.today().strftime('%Y-%m')

    # Load current shard only (not all history)
    records = load_shard(entity, year_month)
    records.append(record)
    save_shard(entity, records, year_month)
    _ensure_shard_registered(entity, year_month)

    return record


def get_record(entity: str, field: str, value: Any, hint_month: str = None) -> Optional[dict]:
    """Find a record by field value.

    If hint_month is provided, searches that shard first.
    Otherwise searches from newest shard to oldest (most lookups are recent).
    """
    shards_to_search = list_shards(entity)

    # Check hinted month first
    if hint_month and hint_month in shards_to_search:
        shards_to_search.remove(hint_month)
        shards_to_search.insert(0, hint_month)

    for shard in shards_to_search:
        for record in load_shard(entity, shard):
            if record.get(field) == value:
                return record
    return None


def update_record(entity: str, field: str, value: Any, updates: dict, hint_month: str = None) -> Optional[dict]:
    """Update a record by field value.

    If hint_month is provided, checks that shard first.
    """
    shards_to_search = list_shards(entity)

    if hint_month and hint_month in shards_to_search:
        shards_to_search.remove(hint_month)
        shards_to_search.insert(0, hint_month)

    for shard in shards_to_search:
        records = load_shard(entity, shard)
        for record in records:
            if record.get(field) == value:
                record.update(updates)
                save_shard(entity, records, shard)
                return record
    return None


def get_next_number(entity: str) -> int:
    """Get the next sequential number. Reads meta.yaml only (~50 tokens)."""
    meta = load_meta(entity)
    return meta.get('last_number', 0) + 1


def increment_last_number(entity: str) -> int:
    """Increment and return the new last number. Updates meta.yaml only."""
    meta = load_meta(entity)
    meta['last_number'] = meta.get('last_number', 0) + 1
    save_meta(entity, meta)
    return meta['last_number']


def migrate_to_shards(entity: str) -> None:
    """Migrate a flat records.yaml to monthly shards.

    Groups records by 'created' date into YYYY-MM.yaml files,
    creates meta.yaml, and removes the old records.yaml.
    """
    legacy_path = DATA_DIR / entity / "records.yaml"
    if not legacy_path.exists():
        return

    data = _load_yaml(legacy_path) or {'records': []}
    records = data.get('records', [])

    # Group by month
    by_month: dict[str, list] = {}
    for record in records:
        created = record.get('created', record.get('date', ''))
        if isinstance(created, (date, datetime)):
            month = created.strftime('%Y-%m')
        elif isinstance(created, str) and len(created) >= 7:
            month = created[:7]  # "2026-03-15" → "2026-03"
        else:
            month = date.today().strftime('%Y-%m')
        by_month.setdefault(month, []).append(record)

    # Write shards
    for month, month_records in by_month.items():
        save_shard(entity, month_records, month)

    # Write meta
    meta = {'shards': sorted(by_month.keys())}
    if 'last_number' in data:
        meta['last_number'] = data['last_number']
    save_meta(entity, meta)

    # Remove legacy file
    legacy_path.unlink()


# ============================================================================
# Discussion-specific (convenience wrappers)
# ============================================================================

def get_discussion_file(year_month: str = None) -> Path:
    """Get path to discussion shard file for a given month."""
    return _get_shard_file("discussions", year_month)


def load_discussions(year_month: str = None) -> List[dict]:
    """Load discussions for a month."""
    return load_shard("discussions", year_month)


def save_discussions(data: List[dict], year_month: str = None) -> None:
    """Save discussions for a month."""
    save_shard("discussions", data, year_month)


def add_discussion(member: str, topic: str, file: str, source: str = "manual") -> dict:
    """Add a discussion to the current month."""
    discussions = load_discussions()
    record = {
        'date': date.today().isoformat(),
        'member': member,
        'topic': topic,
        'file': file,
        'source': source
    }
    discussions.append(record)
    save_discussions(discussions)
    return record


def list_discussion_months() -> List[str]:
    """List all months with discussions."""
    return list_shards("discussions")


def is_meeting_processed(meeting_id: str) -> bool:
    """Check if a meeting has already been documented."""
    for year_month in list_discussion_months():
        for d in load_discussions(year_month):
            if d.get('meeting_id') == meeting_id:
                return True
    return False


def get_discussion_by_meeting_id(meeting_id: str) -> Optional[dict]:
    """Find a discussion record by its meeting ID."""
    for year_month in list_discussion_months():
        for d in load_discussions(year_month):
            if d.get('meeting_id') == meeting_id:
                return d
    return None


