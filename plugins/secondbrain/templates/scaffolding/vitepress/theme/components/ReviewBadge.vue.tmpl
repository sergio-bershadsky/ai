  padding: 0.25rem 0;
  margin-bottom: 0.5rem;
}

.review-badge--fresh {
  color: var(--vp-c-success-1);
}

.review-badge--aging {
  color: var(--vp-c-warning-1);
}

.review-badge--stale {
  color: var(--vp-c-danger-1);
}

.review-badge--never {
  color: var(--vp-c-text-3);
}

.review-badge__count {
  opacity: 0.7;
}
</style>
